# Solvo Backend Environment Variables
# Copy this to .env and fill in your values

# ── Database ──
DATABASE_URL=postgresql+asyncpg://solvo:solvo_secret@localhost:5432/solvo_db

# ── JWT Auth ──
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Kora API ──
KORA_API_BASE_URL=https://api.korapay.com/merchant/api/v1
KORA_API_KEY=your-kora-api-key
KORA_ENCRYPTION_KEY=your-kora-encryption-key
KORA_MOCK_MODE=true

# ── App ──
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
